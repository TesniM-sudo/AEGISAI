from __future__ import annotations

"""Lightweight reinforcement learning agent (tabular Q-learning).

This module learns an action policy over 3 discrete risk states:
    0 = low, 1 = medium, 2 = high

Actions:
    0 = Invest, 1 = Hold, 2 = Diversify

Where RL happens:
    - `update_q(...)` performs the Q-learning update.
"""

from pathlib import Path
from typing import Tuple

import numpy as np
from joblib import dump, load


PROJECT_DIR = Path(__file__).resolve().parent
MODEL_DIR = PROJECT_DIR / "decision_models"
Q_PATH = MODEL_DIR / "q_table.joblib"

ALPHA = 0.1
GAMMA = 0.9
EPSILON = 0.1

N_STATES = 3
N_ACTIONS = 3

_CACHED_Q = None


def _init_q() -> np.ndarray:
    return np.zeros((N_STATES, N_ACTIONS), dtype=float)


def load_q_table() -> np.ndarray:
    global _CACHED_Q
    if _CACHED_Q is not None:
        return _CACHED_Q

    MODEL_DIR.mkdir(parents=True, exist_ok=True)
    if Q_PATH.exists():
        _CACHED_Q = load(Q_PATH)
        return _CACHED_Q

    _CACHED_Q = _init_q()
    dump(_CACHED_Q, Q_PATH)
    return _CACHED_Q


def save_q_table(q_table: np.ndarray) -> None:
    global _CACHED_Q
    MODEL_DIR.mkdir(parents=True, exist_ok=True)
    _CACHED_Q = q_table
    dump(q_table, Q_PATH)


def choose_action(state: int, epsilon: float = EPSILON) -> int:
    """Epsilon-greedy policy."""
    q = load_q_table()
    state = int(np.clip(state, 0, N_STATES - 1))

    if np.random.random() < float(epsilon):
        return int(np.random.randint(0, N_ACTIONS))
    return int(np.argmax(q[state]))


def update_q(state: int, action: int, reward: float, next_state: int) -> np.ndarray:
    """Q-learning update: Q[s,a] <- Q[s,a] + alpha * (r + gamma*max_a' Q[s',a'] - Q[s,a])."""
    q = load_q_table()
    s = int(np.clip(state, 0, N_STATES - 1))
    a = int(np.clip(action, 0, N_ACTIONS - 1))
    ns = int(np.clip(next_state, 0, N_STATES - 1))

    td_target = float(reward) + GAMMA * float(np.max(q[ns]))
    td_error = td_target - float(q[s, a])
    q[s, a] = float(q[s, a]) + ALPHA * td_error

    save_q_table(q)
    return q


def action_to_text(action: int) -> str:
    action = int(action)
    if action == 0:
        return "Invest"
    if action == 1:
        return "Hold"
    if action == 2:
        return "Diversify"
    return "Hold"


# --- Explainability (NEW) ---
# Explanations are based purely on Q-values.
# Q(s, a) represents the expected future reward of taking action `a` in state `s`.
# The greedy RL decision principle is to choose the action with the highest Q-value.
def explain_action(state: int, action: int, q_table: np.ndarray) -> str:
    """Explain the chosen action in human-readable form using Q-values."""
    s = int(np.clip(state, 0, N_STATES - 1))
    a = int(np.clip(action, 0, N_ACTIONS - 1))

    q_values = np.asarray(q_table[s], dtype=float)
    best_action = int(np.argmax(q_values))
    best_value = float(np.max(q_values))
    chosen_value = float(q_values[a])

    state_text = {0: "low risk", 1: "medium risk", 2: "high risk"}[s]
    action_text = {0: "invest", 1: "hold", 2: "diversify"}[a]
    best_action_text = {0: "invest", 1: "hold", 2: "diversify"}[best_action]

    if a == best_action:
        why = (
            f"The agent selected '{action_text}' because it has the highest expected reward "
            f"for this {state_text} situation (Q={chosen_value:.2f})."
        )
    else:
        why = (
            f"The agent selected '{action_text}' even though '{best_action_text}' has a higher expected reward "
            f"in this {state_text} situation (chosen Q={chosen_value:.2f}, best Q={best_value:.2f}). "
            "This can happen due to exploration (epsilon-greedy)."
        )

    if s == 2:
        emphasis = " In high-risk conditions, the policy tends to favor actions that reduce exposure and stabilize outcomes."
    elif s == 0:
        emphasis = " In low-risk conditions, the policy tends to favor opportunity-seeking actions while staying mindful of risk."
    else:
        emphasis = " In medium-risk conditions, the policy aims to balance growth and safety."

    return why + emphasis


def explain_why_not(state: int, action: int, q_table: np.ndarray) -> str:
    """Contrastive explanation: why other actions were not chosen."""
    s = int(np.clip(state, 0, N_STATES - 1))
    a = int(np.clip(action, 0, N_ACTIONS - 1))
    q_values = np.asarray(q_table[s], dtype=float)
    chosen_value = float(q_values[a])

    action_names = {0: "invest", 1: "hold", 2: "diversify"}
    alternatives = []
    for other_action in range(N_ACTIONS):
        if other_action == a:
            continue
        alternatives.append((other_action, float(q_values[other_action])))

    alternatives.sort(key=lambda item: item[1], reverse=True)
    top_alt_action, top_alt_value = alternatives[0]
    return (
        f"The agent did not choose '{action_names[top_alt_action]}' because its expected reward "
        f"is lower for this state (Q={top_alt_value:.2f}) than the chosen action (Q={chosen_value:.2f})."
    )


def apply_feedback(state: int, action: int, reward: float, next_state: int) -> np.ndarray:
    """Public feedback hook used by the app/chatbot to update RL behavior."""
    return update_q(state=state, action=action, reward=reward, next_state=next_state)


def simulate_reward(prev_state: int, next_state: int) -> int:
    """Simple reward shaping used when real outcomes aren't available yet.

    +1 if risk improved (next_state lower), else -1.
    """
    return 1 if int(next_state) < int(prev_state) else -1
